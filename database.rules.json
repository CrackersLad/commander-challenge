{
  "rules": {
    ".read": false,
    ".write": false,

    "global_archives": {
      ".read": true,
      ".write": false
    },
    "stats": {
      ".read": true,
      ".write": false
    },
    
    "admins": {
      ".read": false,
      ".write": false
    },

    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "webhooks": {
      "$roomId": {
        ".read": true,
        ".write": "newData.val() == null || (newData.child('url').val().matches(/^https:\\/\\/discord\\.com\\/api\\/webhooks\\//) && newData.child('url').val().length < 200)"
      }
    },
    "rooms": {
      "$roomId": {
        ".read": true,
        ".write": true
      }
    }
  }
}